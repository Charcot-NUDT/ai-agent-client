# OpenAI Compatible Models (e.g., GPT, DeepSeek, Qwen)
# For OpenAI API (GPT models)
OPENAI_API_KEY="YOUR_ACTUAL_OPENAI_API_KEY"
# Optional: If you use a custom base URL for OpenAI compatible APIs (e.g., for DeepSeek, Qwen)
# OPENAI_BASE_URL="YOUR_CUSTOM_OPENAI_COMPATIBLE_BASE_URL"
GPT_MODEL_NAME="gpt-4o" # Or "gpt-3.5-turbo", etc.

# For Basic Client (e.g., DeepSeek, Qwen via OpenAI compatible API)
BASIC_MODEL_API_KEY="YOUR_ACTUAL_BASIC_MODEL_API_KEY" # Can be the same as OPENAI_API_KEY if using same provider
# Optional: If you use a custom base URL for your basic model
# BASIC_MODEL_BASE_URL="YOUR_BASIC_MODEL_CUSTOM_BASE_URL"
BASIC_MODEL_NAME="deepseek-chat" # Or "qwen-turbo", etc.

# Anthropic Claude Model
ANTHROPIC_API_KEY="YOUR_ACTUAL_ANTHROPIC_API_KEY"
CLAUDE_MODEL_NAME="claude-3-5-sonnet-20240620" # Or other Claude models