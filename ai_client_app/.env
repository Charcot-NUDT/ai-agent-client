# OpenAI 兼容 API 配置 (GPTClient)
# 如果使用 OpenAI 官方接口，OPENAI_BASE_URL 无需设置或设置为默认值。
# OPENAI_API_KEY 是必需的。
OPENAI_API_KEY="sk-your-openai-api-key"
# OPENAI_BASE_URL="https://api.openai.com/v1"

# 基础模型 API 配置 (BasicClient)
# 例如 DeepSeek 或 Qwen 等兼容 OpenAI 接口的模型。
# BASIC_MODEL_API_KEY 是必需的。
# BASIC_MODEL_BASE_URL 通常需要设置为模型的 API 端点，例如 DeepSeek 的为 "https://api.deepseek.com/v1"。
BASIC_MODEL_API_KEY="sk-d108836dfc934bcfb9b0609fdaeec96a"
BASIC_MODEL_BASE_URL="https://api.deepseek.com/v1" # 示例：DeepSeek API 端点

# Anthropic Claude API 配置 (ClaudeClient)
# ANTHROPIC_API_KEY 是必需的。
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"